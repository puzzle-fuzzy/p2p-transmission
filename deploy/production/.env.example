# Copy to deploy/production/.env and replace every placeholder before starting production.
P2P_IMAGE_TAG=2.0.1
P2P_BIND_IP=127.0.0.1
P2P_BIND_PORT=3410
P2P_ALLOWED_ORIGINS=https://p2p.yxswy.com

# Generate independently: openssl rand -base64 48
P2P_CAPABILITY_SECRET=replace-with-a-random-capability-secret-of-at-least-32-bytes
P2P_TURN_SECRET=replace-with-the-coturn-shared-secret
P2P_TURN_URLS=turn:turn.p2p.yxswy.com:3478?transport=udp,turns:turn.p2p.yxswy.com:5349?transport=tcp
P2P_ICE_URLS=stun:stun.l.google.com:19302

# Required release gate: encrypt every verified SQLite backup before offsite upload.
# Configure the named rclone remote separately as root. The age identity must be
# root-owned mode 0600 and must match the public recipient below.
P2P_OFFSITE_BACKUP_REMOTE=s3:p2p-transmission-production/backups
P2P_OFFSITE_BACKUP_AGE_RECIPIENT=age1replace-with-the-public-backup-recipient
P2P_OFFSITE_BACKUP_AGE_IDENTITY=/root/.config/p2p-transmission/backup.agekey

# Per-IP limits per minute. Tune from production metrics, not E2E values.
P2P_SESSION_RATE_MAX=60
P2P_ROOM_RATE_MAX=60
P2P_JOIN_RATE_MAX=120
P2P_SIGNAL_RATE_MAX=600
# Single-host beta alert thresholds. 100 basis points = 1% HTTP 5xx.
P2P_MAX_ACTIVE_WEBSOCKETS=200
P2P_MAX_5XX_RATIO_BPS=100
RUST_LOG=p2p_server=info,tower_http=info
