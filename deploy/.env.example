# Copy to deploy/.env on the Tencent Cloud host. Never commit the copy.

# Shared with coturn. Generate with: openssl rand -base64 48
TURN_SHARED_SECRET=replace-with-at-least-32-random-bytes
TURN_URLS=turn:turn.p2p.yxswy.com:3478?transport=udp,turns:turn.p2p.yxswy.com:5349?transport=tcp
TURN_REALM=turn.p2p.yxswy.com
TURN_EXTERNAL_IP=replace-with-tencent-cloud-public-ip
TURN_TLS_CERT_PATH=/run/coturn/tls/fullchain.pem
TURN_TLS_PRIVATE_KEY_PATH=/run/coturn/tls/privkey.pem
TURN_LISTENING_PORT=3478
TURN_TLS_LISTENING_PORT=5349
TURN_RELAY_PORT_MIN=49160
TURN_RELAY_PORT_MAX=49259

# Keep API limits explicit in production.
REALTIME_TICKET_TTL_SECONDS=60
REALTIME_TICKET_MAX_PER_VISITOR=12
REALTIME_MESSAGES_PER_SECOND=30
REALTIME_OUTBOUND_QUEUE_MAX_MESSAGES=128
REALTIME_OUTBOUND_QUEUE_MAX_BYTES=1048576

# The web image defaults to API TURN mode; set this to off only for a controlled
# pre-TURN smoke test.
VITE_TURN_MODE=api
VITE_STUN_URLS=
# Change this to the actual release version when publishing a new web image.
VITE_APP_VERSION=1.0.0
