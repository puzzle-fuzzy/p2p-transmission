{
  "name": "p2p-transmission",
  "version": "1.0.0",
  "private": true,
  "description": "临时、点对点的文本与文件传输工具。",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/puzzle-fuzzy/p2p-transmission.git"
  },
  "homepage": "https://p2p.yxswy.com",
  "bugs": {
    "url": "https://github.com/puzzle-fuzzy/p2p-transmission/issues"
  },
  "keywords": [
    "p2p",
    "webrtc",
    "file-transfer",
    "text-transfer",
    "bun",
    "react",
    "vite"
  ],
  "type": "module",
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": "1.3.14"
  },
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "verify": "turbo run lint test typecheck build",
    "e2e": "bun run --cwd apps/web e2e",
    "check:docs": "python scripts/check-doc-links.py"
  },
  "devDependencies": {
    "turbo": "^2.6.3"
  }
}
