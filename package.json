{
  "name": "p2p-transmission-browser-tests",
  "version": "2.0.1",
  "private": true,
  "description": "P2P Transmission Rust Web 的浏览器验收工具。",
  "license": "MIT",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": "1.3.14"
  },
  "scripts": {
    "e2e": "playwright test --config e2e/playwright.smoke.config.ts",
    "e2e:full": "playwright test --config e2e/playwright.config.ts",
    "e2e:interop": "playwright test --config e2e/playwright.interop.config.ts",
    "e2e:performance": "playwright test --config e2e/playwright.performance.config.ts",
    "e2e:public": "playwright test --config e2e/playwright.public.config.ts",
    "e2e:stress": "playwright test --config e2e/playwright.stress.config.ts",
    "check:docs": "python scripts/check-doc-links.py",
    "test:service-worker": "bun test scripts/service-worker.test.ts"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.52.0"
  }
}
