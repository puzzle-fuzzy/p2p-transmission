# HTTP/signaling service
PORT=3000
STUN_URLS=stun:stun.l.google.com:19302
CORS_ALLOWED_ORIGINS=http://localhost:5713
TRUST_PROXY=false
TRUSTED_PROXY_IPS=

# API-issued TURN credentials (enable TURN_URLS and TURN_SHARED_SECRET together).
# TURN_URLS=turn:turn.example.com:3478?transport=udp,turns:turn.example.com:5349?transport=tcp
# This deliberately invalid placeholder must be replaced with a random secret of at least 32 bytes.
# TURN_SHARED_SECRET=CHANGE_ME_NOT_A_SECRET
TURN_CREDENTIAL_GRACE_SECONDS=300

# coturn config generation (bun run turn:config)
# TURN_REALM=turn.example.com
# TURN_EXTERNAL_IP=203.0.113.10
# TURN_TLS_CERT_PATH=/run/coturn/tls/fullchain.pem
# TURN_TLS_PRIVATE_KEY_PATH=/run/coturn/tls/privkey.pem
# TURN_LISTENING_PORT=3478
# TURN_TLS_LISTENING_PORT=5349
# TURN_RELAY_PORT_MIN=49160
# TURN_RELAY_PORT_MAX=49259
