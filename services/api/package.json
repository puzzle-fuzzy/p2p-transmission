{
  "name": "api",
  "private": true,
  "version": "1.0.0",
  "description": "P2P Transmission 的 Bun/Elysia 信令与房间 API。",
  "type": "module",
  "scripts": {
    "build": "bun build src/index.ts --target=bun --outdir=dist",
    "dev": "bun run src/index.ts",
    "lint": "oxlint src scripts",
    "test": "bun test",
    "turn:config": "bun run scripts/render-coturn-config.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@elysia/cors": "^1.4.2",
    "@p2p/contracts": "workspace:*",
    "elysia": "latest"
  },
  "devDependencies": {
    "bun-types": "latest",
    "oxlint": "^1.71.0",
    "typescript": "^7.0.2"
  },
  "module": "src/index.js"
}
